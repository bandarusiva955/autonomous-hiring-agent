from flask import Flask, render_template, request, jsonify
from werkzeug.utils import secure_filename
import resume_parser
from config import Config
import logging
from engine.pipeline import run_pipeline
from report.report_generator import generate_report

app = Flask(__name__, template_folder='templates')
app.config.from_object(Config)

# Configure logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Allowed file extensions
ALLOWED_EXTENSIONS = {'pdf', 'docx'}

def allowed_file(filename):
    """Check if file extension is allowed."""
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS

def validate_and_extract_resume(file):
    """
    Validates and extracts text from resume file.
    
    Args:
        file: File object from request.files
        
    Returns:
        tuple: (success: bool, data: str|error_message)
    """
    # Validate file exists
    if not file or file.filename == '':
        return False, 'No file selected'
    
    # Validate file extension
    if not allowed_file(file.filename):
        return False, f'Unsupported file format. Allowed: {", ".join(ALLOWED_EXTENSIONS)}'
    
    # Validate file size
    file.seek(0, 2)  # Seek to end
    file_size = file.tell()
    file.seek(0)  # Reset to start
    
    if file_size > app.config['MAX_RESUME_FILE_SIZE']:
        max_size_mb = app.config['MAX_RESUME_FILE_SIZE'] / (1024 * 1024)
        return False, f'File too large. Maximum size: {max_size_mb}MB'
    
    # Extract text based on file type
    try:
        secure_name = secure_filename(file.filename)
        file_type = secure_name.rsplit('.', 1)[1].lower()
        
        if file_type == 'pdf':
            resume_text = resume_parser.parse_pdf(file)
        elif file_type == 'docx':
            resume_text = resume_parser.parse_docx(file)
        
        if not resume_text or resume_text.strip() == '':
            return False, 'No text extracted from resume. Please check the file format.'
        
        return True, resume_text
        
    except AttributeError as e:
        logger.error(f"Resume parser function error: {e}")
        return False, 'Resume parser module missing required functions (parse_pdf/parse_docx)'
    except Exception as e:
        logger.error(f"Error extracting resume text: {e}")
        return False, f'Error extracting text from resume: {str(e)}'

def process_resume(resume_text):
    """
    Processes resume text through the analysis pipeline.
    
    Args:
        resume_text: Extracted resume text
        
    Returns:
        tuple: (success: bool, report: dict|error_message)
    """
    try:
        # Run complete analysis pipeline
        pipeline_data = run_pipeline(resume_text)
        
        # Check for pipeline errors
        if pipeline_data.get('metadata', {}).get('status') == 'error':
            error = pipeline_data.get('metadata', {}).get('error', 'Unknown error')
            logger.error(f"Pipeline error: {error}")
            return False, f'Analysis error: {error}'
        
        # Generate structured report
        report = generate_report(pipeline_data)
        return True, report
        
    except ImportError as e:
        logger.error(f"Pipeline import error: {e}")
        return False, 'Analysis pipeline not properly configured'
    except Exception as e:
        logger.error(f"Pipeline execution error: {e}")
        return False, f'Error during analysis: {str(e)}'

@app.route('/', methods=['GET', 'POST'])
def index():
    """Handle resume upload and analysis."""
    if request.method == 'POST':
        # Validate and extract resume
        success, result = validate_and_extract_resume(request.files.get('resume_file'))
        if not success:
            return render_template('index.html', error=result), 400
        
        resume_text = result
        
        # Process resume through pipeline
        success, result = process_resume(resume_text)
        if not success:
            return render_template('index.html', error=result), 500
        
        report = result
        return render_template('report.html', report=report)
    
    return render_template('index.html')